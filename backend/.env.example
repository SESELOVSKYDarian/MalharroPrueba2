# Puerto del servidor Express
PORT=4000

# URL del frontend (Next.js)
CLIENT_URL=http://localhost:3000

# Credenciales PostgreSQL
PGHOST=localhost
PGPORT=5432
PGDATABASE=malharro
PGUSER=postgres
PGPASSWORD=postgres
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/malharro

# Autenticación y seguridad
JWT_SECRET=cambia-esta-clave
JWT_EXPIRES_IN=8h
ADMIN_EMAIL=admin@malharro.edu
ADMIN_PASSWORD=cambia-esta-contraseña

# Configuración SMTP para envío de códigos
# Deja SMTP_HOST vacío para que el backend imprima los correos en consola durante el desarrollo.
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_DEV_CONSOLE=true
EMAIL_FROM="Malharro" <no-reply@malharro.edu>
